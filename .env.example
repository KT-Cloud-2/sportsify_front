# =============================================
# .env.example — 환경변수 템플릿
# 복사 명령:
#   cp .env.example .env.local   # 로컬 개발용
#   cp .env.example .env.dev     # 개발 서버용
#   cp .env.example .env.prod    # 운영 서버용
# .env.local, .env.dev, .env.prod 는 절대 커밋하지 않는다
# =============================================

# Spring 프로파일 (local | dev | prod)
SPRING_PROFILES_ACTIVE=test

# Database
DB_HOST=localhost
DB_NAME=sportsify
DB_USERNAME=sportsify
DB_PASSWORD=sportsify

# Redis
REDIS_HOST=localhost
REDIS_PASSWORD=

# JWT (최소 32자 이상의 랜덤 문자열)
JWT_SECRET=change-this-to-a-random-secret-at-least-32-chars

# OAuth2 — Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth2 — Kakao
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# Frontend URL (OAuth2 콜백 리다이렉트)
FRONTEND_URL=http://localhost:3000

# Email (prod 전용)
MAIL_HOST=
MAIL_USERNAME=
MAIL_PASSWORD=

# MQTT (prod 전용)
MQTT_HOST=
MQTT_CLIENT_ID=sportsify-server
MQTT_USERNAME=
MQTT_PASSWORD=

# Grafana (prod 전용 — docker-compose.infra.yml)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=
